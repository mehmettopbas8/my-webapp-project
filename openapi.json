{
  "openapi": "3.0.3",
  "info": {
    "title": "Todo Tasks API",
    "version": "1.0.0",
    "description": "OpenAPI specification for the simple CRUD Tasks API implemented in the project. Endpoints are exposed under /api/tasks/* as configured in `web.xml`."
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "Local server (root context)"
    },
    {
      "url": "http://localhost:8080/my-webapp-project",
      "description": "Local server (WAR context shown in project target)"
    }
  ],
  "paths": {
    "/api/tasks": {
      "get": {
        "tags": ["tasks"],
        "summary": "List tasks",
        "description": "Returns an array of all tasks. Corresponds to TaskDAO.getAll() called by `TasksServlet#doGet` when no id is present.",
        "responses": {
          "200": {
            "description": "A JSON array of Task objects",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Task"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["tasks"],
        "summary": "Create a new task",
        "description": "Creates a new task. Requires a JSON body with at least `title`. The servlet enforces that title is present; `completed` is optional (defaults to false). On success returns 201 with the created Task (id assigned by DB).",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TaskCreate"
              },
              "example": {
                "title": "Buy milk",
                "completed": false
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Task created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Task"
                }
              }
            }
          },
          "400": {
            "description": "Bad request (invalid JSON or missing required fields)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/tasks/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "integer",
            "format": "int32"
          },
          "description": "Numeric id of the task"
        }
      ],
      "get": {
        "tags": ["tasks"],
        "summary": "Get a task by id",
        "description": "Returns a single Task object for the given id. Returns 404 if not found.",
        "responses": {
          "200": {
            "description": "Task found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Task"
                }
              }
            }
          },
          "404": {
            "description": "Task not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "examples": {
                  "notFound": {
                    "value": {
                      "message": "Not Found"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": ["tasks"],
        "summary": "Update a task",
        "description": "Updates task with given id. The servlet parses id from path and merges it into the body (input.setId(id)). The request body should contain `title` and optionally `completed`. On success returns 204 No Content. Returns 404 if task doesn't exist.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TaskUpdate"
              },
              "example": {
                "title": "Buy almond milk",
                "completed": true
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Task updated (no content)"
          },
          "400": {
            "description": "Bad request (invalid JSON or invalid body)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Task not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["tasks"],
        "summary": "Delete a task",
        "description": "Deletes the task with the given id. Returns 204 on successful deletion, 404 if not found.",
        "responses": {
          "204": {
            "description": "Task deleted (no content)"
          },
          "404": {
            "description": "Task not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Task": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32",
            "example": 1
          },
          "title": {
            "type": "string",
            "example": "Buy milk"
          },
          "completed": {
            "type": "boolean",
            "example": false
          }
        },
        "required": ["id", "title", "completed"],
        "description": "Task resource as returned by the API (id always present in responses)."
      },
      "TaskCreate": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "Buy milk"
          },
          "completed": {
            "type": "boolean",
            "example": false,
            "description": "Optional; defaults to false when not provided."
          }
        },
        "required": ["title"],
        "description": "Request body for creating a Task. `title` is required."
      },
      "TaskUpdate": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "Buy almond milk"
          },
          "completed": {
            "type": "boolean",
            "example": true
          }
        },
        "required": ["title"],
        "description": "Request body for updating a Task. `id` is taken from the path; provide `title` and optionally `completed`."
      },
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "Error message describing what went wrong"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "tasks",
      "description": "Operations related to todo tasks"
    }
  ]
}
